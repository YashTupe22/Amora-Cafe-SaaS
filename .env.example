# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Synplix Cafe Suite
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (Client SDK — NEXT_PUBLIC_ is intentional; these are NOT secrets)
# Firebase API keys identify your project; security is enforced via
# Firebase Security Rules + Auth tokens, not by hiding the key.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── PostHog Analytics (NEXT_PUBLIC_ is intentional — client-side SDK key)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────────────────────────────────────
# ── Firebase Admin SDK (SERVER-ONLY — NEVER prefix with NEXT_PUBLIC_)
# Used for verifying Firebase ID tokens in API routes.
# Generate a service-account JSON from Firebase Console →
#   Project Settings → Service Accounts → Generate new private key
# Then copy the three fields below from that JSON.
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private_key value exactly, including "-----BEGIN/END PRIVATE KEY-----"
# The literal \n escape sequences are fine — the code converts them to real newlines.
FIREBASE_ADMIN_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# ── Razorpay (SERVER-ONLY unless noted)
# ─────────────────────────────────────────────────────────────────────────────

# Client-safe: used in the Razorpay checkout modal (NEXT_PUBLIC_ is intentional)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# SERVER-ONLY — never prefix with NEXT_PUBLIC_
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Razorpay Plan IDs (create in Razorpay Dashboard → Subscriptions → Plans)
RAZORPAY_PLAN_STARTER_MONTHLY=
RAZORPAY_PLAN_STARTER_ANNUAL=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_ANNUAL=
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=
RAZORPAY_PLAN_ENTERPRISE_ANNUAL=
