# ────────────────────────────────────────────────────────────────
# Synplix — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ────────────────────────────────────────────────────────────────

# ── Firebase (required) ──────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── PostHog Analytics (optional but recommended) ─────────────────
# Get these from https://app.posthog.com → Project Settings → Keys
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Admin migration secret (server-only) ─────────────────────────
# Used to protect one-off admin endpoints such as:
#   /api/subscription/admin/fix-active-free
# Never expose this value to the browser or share publicly.
ADMIN_MIGRATION_SECRET=change_me_to_a_random_string
